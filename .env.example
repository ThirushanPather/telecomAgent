# AWS Bedrock (required)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Webhook (optional — fires on every approved RPA action)
WEBHOOK_URL=https://webhook.site/your-uuid-here

# Gmail SMTP (optional — if absent, email sending is simulated)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
SMTP_RECIPIENT=inbox-to-receive-test-emails@gmail.com

# Twilio WhatsApp (optional — if absent, WhatsApp sending is simulated)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+27XXXXXXXXX
